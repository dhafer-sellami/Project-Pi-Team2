
{% block title %}List of Articles{% endblock %}

{% block body %}
    <h1>List of Articles</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Content</th>
                <th>Creation Date</th>
                <th>User</th>
            </tr>
        </thead>
        <tbody>
            {% for article in artcles %}
                <tr>
                    <td>{{ article.titre }}</td>
                    <td>{{ article.content }}</td>
                    <td>{{ article.datecreation|date('Y-m-d') }}</td>
                    <td>{{ article.userID }}
                    <td>
                    <a href="{{ path('delete_article', { id: article.id }) }}" 
                    class="btn btn-danger" 
                    onclick="return confirm('Are you sure you want to delete this article?');">
                    Delete
                    </a>
                    <a href="{{ path('edit_article', { id: article.id }) }}" class="btn btn-warning">Modify</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">No articles found.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
